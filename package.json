{
  "name": "angaza-dryland",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-first digital ecosystem for dryland value chains",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "docker compose -f docker-compose.dev.yaml up",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev"
  },
  "workspaces": [
    "api",
    "web"
  ]
}
